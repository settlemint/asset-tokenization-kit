{
  "name": "@atk/settlemint",
  "type": "module",
  "scripts": {
    "lint": "biome check --write --unsafe",
    "codegen": "settlemint codegen",
    "typecheck": "tsgo --noEmit",
    "posttypecheck": "bun gql-tada check"
  },
  "exports": {
    "./*": {
      "import": "./src/lib/settlemint/*.ts",
      "types": "./src/lib/settlemint/*.ts"
    }
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@settlemint/sdk-blockscout": "2.5.11",
    "@settlemint/sdk-hasura": "2.5.11",
    "@settlemint/sdk-ipfs": "2.5.11",
    "@settlemint/sdk-minio": "2.5.11",
    "@settlemint/sdk-portal": "2.5.11",
    "@settlemint/sdk-thegraph": "2.5.11"
  }
}
