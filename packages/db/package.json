{
  "name": "@atk/db",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./schemas/*": {
      "import": "./src/schemas/*.ts",
      "types": "./src/schemas/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "biome check --write --unsafe",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:ci": "bun test:coverage"
  },
  "devDependencies": {
    "@tools/typescript-config": "workspace:*",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@settlemint/sdk-hasura": "2.5.13",
    "@settlemint/sdk-utils": "2.5.13",
    "@tanstack/react-start": "1.131.26",
    "drizzle-orm": "0.44.4",
    "viem": "2.34.0",
    "zod": "4.0.17"
  }
}
